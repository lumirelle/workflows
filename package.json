{
  "name": "workflows",
  "type": "module",
  "version": "3.0.22",
  "private": true,
  "scripts": {
    "prepare": "simple-git-hooks",
    "build": "echo 'Build completed!'",
    "lint": "bun --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "typecheck": "echo 'Type check successful!'",
    "unused": "echo 'Unused check successful!'",
    "pubcheck": "echo 'Distribution check successful!'",
    "check": "bun run --parallel lint typecheck unused pubcheck",
    "test": "echo 'Tests passed!'",
    "prerelease": "bun run build && bun run --parallel check test",
    "release": "bumpp && bun run ./release.sh"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@lumirelle/oxlint-config": "^0.2.1",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-oxlint": "^1.58.0",
    "nano-staged": "^0.9.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint",
      "eslint"
    ]
  }
}
