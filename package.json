{
  "name": "workflows",
  "type": "module",
  "version": "5.0.1",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "prepare": "simple-git-hooks",
    "build": "echo 'Build completed!'",
    "lint": "bun --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "typecheck": "echo 'Type check successful!'",
    "unused": "echo 'Unused check successful!'",
    "check": "bun run --parallel lint typecheck unused",
    "test": "echo 'Tests passed!'",
    "prerelease": "bun run --parallel check test",
    "release": "bumpp && bun run ./release.sh"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@lumirelle/oxlint-config": "^0.6.0",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-oxlint": "^1.66.0",
    "nano-staged": "^1.0.2",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}
