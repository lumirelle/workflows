amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"

import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  // Code
  ["oxlint"] = Builtins.ox_lint
  ["eslint"] = (Builtins.eslint) {
    batch = false
    glob =
      List(
        // Code
        "*.js",
        "*.mjs",
        "*.cjs",
        "*.jsx",
        "*.ts",
        "*.mts",
        "*.cts",
        "*.tsx",
        // Configurations
        "*.json",
        "*.jsonc",
        "*.yaml",
        "*.yml",
        "*.toml",
        // Documentations
        "*.md",
        "*.mdc",
        "*.mdx",
      )
    depends = List("oxlint")
  }

  // Configurations
  ["stylua"] = (Builtins.stylua) {
    glob = List("**/*.lua")
  }
  ["hk"] = (Builtins.pkl) {
    glob = List("hk.pkl")
    check = "hk validate"
  }
  ["pkl-format"] = (Builtins.pkl_format) {
    glob = List("hk.pkl")
    shell = null
    fix = "pkl format --write {{ files }}"
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
